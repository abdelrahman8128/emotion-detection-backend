# CELL 17e: Export ensemble as single TFLite model
# Strategy: bake the ensemble logic into a wrapper model
# so Flutter only loads ONE .tflite file
# ============================================================
print("\n" + "="*70)
print("EXPORTING ENSEMBLE AS SINGLE TFLITE")
print("="*70)

class EnsembleModel(keras.Model):
    """
    Wraps MLP + Dual model into a single Keras model.
    Input  : tabular features (622-dim)  +  mel image (128×128×1)
    Output : averaged softmax probabilities
    """
    def __init__(self, mlp_model, dual_model, w_mlp=0.5):
        super().__init__()
        self.mlp_model  = mlp_model
        self.dual_model = dual_model
        self.w_mlp      = w_mlp
        self.w_dual     = 1.0 - w_mlp

    def call(self, inputs, training=False):
        tab_inp = inputs['tabular_features']
        img_inp = inputs['mel_image']

        p_mlp  = self.mlp_model(tab_inp, training=training)
        p_dual = self.dual_model(
            {'mel_image': img_inp, 'tabular_features': tab_inp},
            training=training
        )
        return self.w_mlp * p_mlp + self.w_dual * p_dual


