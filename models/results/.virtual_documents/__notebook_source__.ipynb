# CELL 16: Train with Mixup  (fixed for Keras 3)
# ============================================================

def mixup_batch(X_batch, y_batch, alpha=0.3):
    """Interpolate pairs of samples and labels."""
    if alpha <= 0:
        return X_batch, y_batch
    lam   = np.random.beta(alpha, alpha)
    idx   = np.random.permutation(len(X_batch))
    X_mix = lam * X_batch + (1 - lam) * X_batch[idx]
    y_mix = lam * y_batch + (1 - lam) * y_batch[idx]
    return X_mix.astype(np.float32), y_mix.astype(np.float32)


def train_with_mixup(model, X_tr, y_tr, X_v, y_v,
                     epochs, batch_size, callbacks,
                     class_weight_dict, alpha=0.3):
    """
    Manual epoch loop with per-batch Mixup augmentation.

    Key fixes vs previous version:
    • Calls cb.set_model(model) before any epoch callbacks so
      Keras callbacks that use self.model work correctly
    • LR callback uses its own optimizer reference — no self.model needed
    • on_train_begin / on_train_end called for CSVLogger etc.
    """

    best_val_acc   = 0.0
    patience_count = 0
    PATIENCE       = 30

    history_log = {
        'accuracy':     [],
        'val_accuracy': [],
        'loss':         [],
        'val_loss':     [],
        'lr':           []
    }

    n_batches = int(np.ceil(len(X_tr) / batch_size))

    # ── Attach model to every callback ────────────────────────
    for cb in callbacks:
        cb.set_model(model)     # Keras 3: must be called explicitly
        if hasattr(cb, 'set_params'):
            cb.set_params({
                'epochs': epochs,
                'steps':  n_batches,
                'verbose': 1,
                'do_validation': True,
                'metrics': ['loss', 'accuracy', 'val_loss', 'val_accuracy']
            })

    # on_train_begin (needed by CSVLogger to write the header)
    for cb in callbacks:
        if hasattr(cb, 'on_train_begin'):
            cb.on_train_begin()

    for epoch in range(epochs):

        # ── LR update (WarmUpCosineDecay uses its own ref) ────
        for cb in callbacks:
            if hasattr(cb, 'on_epoch_begin'):
                cb.on_epoch_begin(epoch, logs={})

        # ── Shuffle ───────────────────────────────────────────
        perm   = np.random.permutation(len(X_tr))
        X_shuf = X_tr[perm]
        y_shuf = y_tr[perm]

        epoch_losses, epoch_accs = [], []

        # ── Mini-batch loop ───────────────────────────────────
        for b in range(n_batches):
            s  = b * batch_size
            e  = s + batch_size
            Xb = X_shuf[s:e]
            yb = y_shuf[s:e]

            Xb_mix, yb_mix = mixup_batch(Xb, yb, alpha=alpha)

            result = model.train_on_batch(
                Xb_mix, yb_mix,
                class_weight=class_weight_dict
            )
            # result = [loss, accuracy, precision, recall]
            epoch_losses.append(float(result[0]))
            epoch_accs.append(float(result[1]))

        # ── Validation ────────────────────────────────────────
        val_result = model.evaluate(X_v, y_v, verbose=0, batch_size=256)
        val_loss   = float(val_result[0])
        val_acc    = float(val_result[1])
        train_loss = float(np.mean(epoch_losses))
        train_acc  = float(np.mean(epoch_accs))

        # Get current LR from optimizer (works for Keras 3)
        current_lr = float(
            keras.backend.get_value(model.optimizer.learning_rate)
        )

        # ── Record history ────────────────────────────────────
        history_log['loss'].append(train_loss)
        history_log['accuracy'].append(train_acc)
        history_log['val_loss'].append(val_loss)
        history_log['val_accuracy'].append(val_acc)
        history_log['lr'].append(current_lr)

        logs = {
            'loss':         train_loss,
            'accuracy':     train_acc,
            'val_loss':     val_loss,
            'val_accuracy': val_acc,
            'lr':           current_lr
        }

        # ── Epoch-end callbacks (checkpoint, early-stop, CSV) ─
        stop_training = False
        for cb in callbacks:
            if hasattr(cb, 'on_epoch_end'):
                cb.on_epoch_end(epoch, logs=logs)
            # Respect EarlyStopping's stop signal
            if getattr(cb, 'stop_training', False):
                stop_training = True

        print(f"Epoch {epoch+1:3d}/{epochs}  "
              f"loss={train_loss:.4f}  acc={train_acc:.4f}  "
              f"val_loss={val_loss:.4f}  val_acc={val_acc:.4f}  "
              f"lr={current_lr:.2e}")

        # ── Manual best-checkpoint ────────────────────────────
        if val_acc > best_val_acc:
            best_val_acc   = val_acc
            patience_count = 0
            model.save('checkpoints/best_model.keras')
            print(f"  ✓ Best val_acc={best_val_acc:.4f} — checkpoint saved")
        else:
            patience_count += 1

        if stop_training:
            print(f"\nEarly stopping triggered at epoch {epoch+1}")
            print(f"Best val_accuracy: {best_val_acc:.4f}")
            break

    # on_train_end
    for cb in callbacks:
        if hasattr(cb, 'on_train_end'):
            cb.on_train_end()

    return history_log


