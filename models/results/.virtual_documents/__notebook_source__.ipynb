      f"({wrong_mask.mean()*100:.1f}%)")
print(f"  Hard sample distribution :")
hard_labels  = np.argmax(y_hard, axis=1)
for i, emo in enumerate(label_encoder.classes_):
    n = (hard_labels == i).sum()
    print(f"    {emo:12s}: {n}")

# ── Fine-tune with tiny LR on hard examples ───────────────────
best_model.compile(
    optimizer=keras.optimizers.AdamW(
        learning_rate=5e-5,     # 20× smaller than training LR
        weight_decay=1e-5
    ),
    loss=focal_loss_fn,
    metrics=['accuracy',
             keras.metrics.Precision(name='precision'),
