# CELL 6: Dataset Loaders  (RAVDESS / TESS / CREMA-D unchanged)
# ============================================================
def load_ravdess_data(base_path):
    data = []
    ravdess_emotions = {
        '01': 'neutral', '02': 'calm',  '03': 'happy',
        '04': 'sad',     '05': 'angry', '06': 'fearful',
        '07': 'disgust', '08': 'surprised'
    }
    try:
        audio_files = glob.glob(
            os.path.join(base_path, '**', '*.wav'), recursive=True
        )
        print(f"  Found {len(audio_files)} files in RAVDESS")
        for file in audio_files:
            filename = os.path.basename(file)
            parts = filename.replace('.wav', '').split('-')
            if len(parts) == 7:
                emotion = ravdess_emotions.get(parts[2])
                if emotion:
                    data.append({
                        'path':      file,
                        'emotion':   EMOTION_MAPPING.get(emotion, emotion),
                        'source':    'RAVDESS',
                        'intensity': 'strong' if parts[3] == '02' else 'normal'
                    })
    except Exception as e:
        print(f"Error loading RAVDESS: {e}")
    print(f"  Parsed {len(data)} valid files from RAVDESS")
    return pd.DataFrame(data)


def load_tess_data(base_path):
    data = []
    try:
        audio_files = glob.glob(
            os.path.join(base_path, '**', '*.wav'), recursive=True
        )
        print(f"  Found {len(audio_files)} files in TESS")
        for file in audio_files:
            parent     = os.path.basename(os.path.dirname(file))
            parts      = parent.split('_')
            emotion_raw = '_'.join(parts[1:]).lower() if len(parts) >= 2 else None
            if not emotion_raw:
                fname   = os.path.basename(file).replace('.wav', '')
                fparts  = fname.split('_')
                emotion_raw = fparts[-1].lower() if len(fparts) >= 2 else None
            if not emotion_raw:
                continue
            data.append({
                'path':      file,
                'emotion':   EMOTION_MAPPING.get(emotion_raw, emotion_raw),
                'source':    'TESS',
                'intensity': 'normal'
            })
    except Exception as e:
        print(f"Error loading TESS: {e}")
    print(f"  Parsed {len(data)} valid files from TESS")
    return pd.DataFrame(data)


def load_crema_data(base_path):
    data = []
    crema_emotions = {
        'ANG': 'angry', 'DIS': 'disgust', 'FEA': 'fear',
        'HAP': 'happy', 'NEU': 'neutral', 'SAD': 'sad'
    }
    intensity_map = {'HI': 'high', 'MD': 'medium', 'LO': 'low', 'XX': 'unspecified'}
    try:
        audio_files = glob.glob(
            os.path.join(base_path, '**', '*.wav'), recursive=True
        )
        print(f"  Found {len(audio_files)} files in CREMA-D")
        for file in audio_files:
            filename = os.path.basename(file)
            parts    = filename.replace('.wav', '').split('_')
            if len(parts) >= 3:
                emotion = crema_emotions.get(parts[2].upper())
                if emotion:
                    intensity_code = parts[3].upper() if len(parts) > 3 else 'XX'
                    data.append({
                        'path':      file,
                        'emotion':   EMOTION_MAPPING.get(emotion, emotion),
                        'source':    'CREMA-D',
                        'intensity': intensity_map.get(intensity_code, 'unspecified')
                    })
    except Exception as e:
        print(f"Error loading CREMA-D: {e}")
    print(f"  Parsed {len(data)} valid files from CREMA-D")
    return pd.DataFrame(data)


# ============================================================
# CELL 7: NEW – ESD Dataset Loader
# ============================================================
def load_esd_data(base_path):
    """
    ESD structure:
      <base>/Emotion Speech Dataset/<speaker_id>/<Emotion>/<speaker>_<id>.wav

    Example:
      .../0001/Angry/0001_000351.wav
      .../0001/Happy/0001_000701.wav

    Emotion folders: Angry, Happy, Sad, Surprise, Neutral
    We derive the emotion label directly from the parent folder name.
    Text files (.txt) are skipped automatically.
    """
    data = []

    # ESD uses title-case folder names → map to our standard labels
    esd_folder_to_emotion = {
        'angry':    'angry',
        'happy':    'happy',
        'sad':      'sad',
        'surprise': 'surprise',
        'neutral':  'neutral',
    }

    try:
        audio_files = glob.glob(
            os.path.join(base_path, '**', '*.wav'), recursive=True
        )
        print(f"  Found {len(audio_files)} .wav files in ESD")

        for file in audio_files:
            try:
                # Parent folder = emotion label  (e.g. "Angry", "Happy")
                emotion_folder = os.path.basename(os.path.dirname(file)).lower()
                emotion = esd_folder_to_emotion.get(emotion_folder)

                if emotion is None:
                    # Folder might be a speaker ID (0001, 0002 …) — skip
                    continue

                data.append({
                    'path':      file,
                    'emotion':   EMOTION_MAPPING.get(emotion, emotion),
                    'source':    'ESD',
                    'intensity': 'normal'
                })
            except Exception:
                continue

        print(f"  Parsed {len(data)} valid files from ESD")

    except Exception as e:
        print(f"Error loading ESD: {e}")

    return pd.DataFrame(data)



