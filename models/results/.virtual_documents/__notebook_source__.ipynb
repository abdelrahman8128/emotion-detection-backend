class FocalLoss(keras.losses.Loss):
    """
    Multiclass focal loss implemented as a proper Keras Loss subclass.

    Using a class instead of a closure fixes:
    • Model serialization  — get_config() lets Keras save/load the loss
    • Custom objects       — registered by class name, not function ref
    • Keras 3 compatibility — no tf.* ops on symbolic tensors
    """
    def __init__(self, gamma=2.0, alpha=0.25,
                 name='focal_loss', **kwargs):
        super().__init__(name=name, **kwargs)
        self.gamma = gamma
        self.alpha = alpha

    def call(self, y_true, y_pred):
        y_true = keras.ops.cast(y_true, dtype='float32')
        y_pred = keras.ops.clip(y_pred, 1e-8, 1.0)

        ce     = -y_true * keras.ops.log(y_pred)
        weight = (self.alpha
                  * y_true
                  * keras.ops.power(1.0 - y_pred, self.gamma))
        fl     = weight * ce
        return keras.ops.mean(keras.ops.sum(fl, axis=-1))

    def get_config(self):
        cfg = super().get_config()
        cfg.update({'gamma': self.gamma, 'alpha': self.alpha})
        return cfg


# Instantiate once — reuse in compile and load_model
focal_loss_fn = FocalLoss(gamma=2.0, alpha=0.25)

print("✓ FocalLoss class defined and instantiated")
