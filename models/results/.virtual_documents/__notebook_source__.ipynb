# ============================================================
# CELL 4: Manual Augmentation (no external library needed)
# ============================================================

def add_noise(audio, noise_factor=0.005):
    """Add Gaussian white noise."""
    noise = np.random.randn(len(audio)).astype(np.float32)
    return audio + noise_factor * noise


def time_stretch(audio, rate=None):
    """Speed up or slow down without changing pitch."""
    rate = rate if rate is not None else np.random.uniform(0.85, 1.15)
    try:
        return librosa.effects.time_stretch(y=audio, rate=float(rate))
    except Exception:
        return audio  # return unchanged if stretch fails


def pitch_shift(audio, sr, n_steps=None):
    """Shift pitch up or down by semitones."""
    n_steps = n_steps if n_steps is not None else np.random.uniform(-3.0, 3.0)
    try:
        return librosa.effects.pitch_shift(
            y=audio, sr=sr, n_steps=float(n_steps)
        )
    except Exception:
        return audio


def add_silence(audio, sr, max_ratio=0.10):
    """Prepend or append a short silence segment."""
    silence_len = int(np.random.uniform(0, max_ratio) * sr)
    silence     = np.zeros(silence_len, dtype=np.float32)
    if np.random.rand() > 0.5:
        return np.concatenate([silence, audio])
    return np.concatenate([audio, silence])


def volume_scale(audio, low=0.7, high=1.3):
    """Randomly scale volume."""
    factor = np.random.uniform(low, high)
    return (audio * factor).astype(np.float32)


def augment_audio(audio, sr, prob=0.5):
    """
    Apply each augmentation independently with probability `prob`.
    Order is randomised each call for extra variety.
    """
    augmentations = [
        lambda a: add_noise(a),
        lambda a: time_stretch(a),
        lambda a: pitch_shift(a, sr),
        lambda a: add_silence(a, sr),
        lambda a: volume_scale(a),
    ]
    # Shuffle order to avoid systematic bias
    np.random.shuffle(augmentations)

    for aug_fn in augmentations:
        if np.random.rand() < prob:
            try:
                audio = aug_fn(audio)
            except Exception:
                pass   # silently skip a failing augmentation

    return audio


print("✓ Augmentation functions ready (pure numpy + librosa, no external libs)")


# ============================================================
# CELL 5: Feature Extraction v3  (622 dims)
# ============================================================
def extract_features(file_path, duration=3, sr=22050, augment=False):
    try:
        load_kwargs = dict(duration=duration, sr=sr)
        if RES_TYPE is not None:
            load_kwargs["res_type"] = RES_TYPE

        audio, sample_rate = librosa.load(file_path, **load_kwargs)

        target_len = sr * duration
        if len(audio) < target_len:
            audio = np.pad(audio, (0, target_len - len(audio)), mode='constant')
        else:
            audio = audio[:target_len]

        if augment:
            audio = augment_audio(audio, sample_rate)
            if len(audio) < target_len:
                audio = np.pad(audio, (0, target_len - len(audio)), mode='constant')
            else:
                audio = audio[:target_len]

        feats = []

        # 1. MFCCs (80 dims)
        mfccs = librosa.feature.mfcc(y=audio, sr=sample_rate, n_mfcc=40)
        feats.extend(np.mean(mfccs.T, axis=0))
        feats.extend(np.std(mfccs.T,  axis=0))

        # 2. MFCC delta (80 dims)
        d1 = librosa.feature.delta(mfccs)
        feats.extend(np.mean(d1.T, axis=0))
        feats.extend(np.std(d1.T,  axis=0))

        # 3. MFCC delta-delta (80 dims)
        d2 = librosa.feature.delta(mfccs, order=2)
        feats.extend(np.mean(d2.T, axis=0))
        feats.extend(np.std(d2.T,  axis=0))

        # 4. MFCC delta covariance diagonal (40 dims)
        mfcc_delta_cov = np.cov(d1)
        feats.extend(np.diag(mfcc_delta_cov))

        # 5. Chroma (24 dims)
        chroma = librosa.feature.chroma_stft(y=audio, sr=sample_rate)
        feats.extend(np.mean(chroma.T, axis=0))
        feats.extend(np.std(chroma.T,  axis=0))

        # 6. Mel Spectrogram (256 dims)
        mel = librosa.feature.melspectrogram(y=audio, sr=sample_rate, n_mels=128)
        feats.extend(np.mean(mel.T, axis=0))
        feats.extend(np.std(mel.T,  axis=0))

        # 7. Log-mel energy bands (16 dims)
        mel_log   = librosa.power_to_db(mel)
        band_size = mel_log.shape[0] // 8
        for b in range(8):
            band = mel_log[b * band_size : (b + 1) * band_size, :]
            feats.append(float(np.mean(band)))
            feats.append(float(np.std(band)))

        # 8. Spectral Contrast (14 dims)
        contrast = librosa.feature.spectral_contrast(y=audio, sr=sample_rate)
        feats.extend(np.mean(contrast.T, axis=0))
        feats.extend(np.std(contrast.T,  axis=0))

        # 9. Tonnetz (12 dims)
        tonnetz = librosa.feature.tonnetz(
            y=librosa.effects.harmonic(audio), sr=sample_rate
        )
        feats.extend(np.mean(tonnetz.T, axis=0))
        feats.extend(np.std(tonnetz.T,  axis=0))

        # 10. Pitch / F0 (4 dims)
        f0, voiced_flag, _ = librosa.pyin(
            audio,
            fmin=librosa.note_to_hz('C2'),
            fmax=librosa.note_to_hz('C7'),
            sr=sample_rate
        )
        f0_clean      = np.where(np.isnan(f0), 0.0, f0)
        voiced_frames = f0_clean[f0_clean > 0]
        feats.append(float(np.mean(voiced_frames)) if len(voiced_frames) > 0 else 0.0)
        feats.append(float(np.std(voiced_frames))  if len(voiced_frames) > 0 else 0.0)
        feats.append(float(np.ptp(voiced_frames))  if len(voiced_frames) > 0 else 0.0)
        feats.append(float(np.mean(voiced_flag.astype(float))))

        # 11. Harmonic / Percussive split (4 dims)
        harmonic, percussive = librosa.effects.hpss(audio)
        h_rms = float(np.sqrt(np.mean(harmonic**2)))
        p_rms = float(np.sqrt(np.mean(percussive**2)))
        feats.append(h_rms)
        feats.append(p_rms)
        feats.append(h_rms / (p_rms + 1e-8))
        feats.append(h_rms / (h_rms + p_rms + 1e-8))

        # 12. Zero-Crossing Rate (2 dims)
        zcr = librosa.feature.zero_crossing_rate(audio)
        feats.append(float(np.mean(zcr)))
        feats.append(float(np.std(zcr)))

        # 13. RMS Energy (2 dims)
        rms = librosa.feature.rms(y=audio)
        feats.append(float(np.mean(rms)))
        feats.append(float(np.std(rms)))

        # 14. Spectral Centroid (2 dims)
        centroid = librosa.feature.spectral_centroid(y=audio, sr=sample_rate)
        feats.append(float(np.mean(centroid)))
        feats.append(float(np.std(centroid)))

        # 15. Spectral Bandwidth (2 dims)
        bandwidth = librosa.feature.spectral_bandwidth(y=audio, sr=sample_rate)
        feats.append(float(np.mean(bandwidth)))
        feats.append(float(np.std(bandwidth)))

        # 16. Spectral Rolloff (2 dims)
        rolloff = librosa.feature.spectral_rolloff(y=audio, sr=sample_rate)
        feats.append(float(np.mean(rolloff)))
        feats.append(float(np.std(rolloff)))

        # 17. Poly Features (4 dims)
        poly = librosa.feature.poly_features(y=audio, sr=sample_rate, order=1)
        feats.extend(np.mean(poly.T, axis=0))
        feats.extend(np.std(poly.T,  axis=0))

        result = np.array(feats, dtype=np.float32)

        if not np.isfinite(result).all():
            result = np.nan_to_num(result, nan=0.0, posinf=0.0, neginf=0.0)

        return result

    except Exception as e:
        print(f"Error processing {file_path}: {e}")
        return None

