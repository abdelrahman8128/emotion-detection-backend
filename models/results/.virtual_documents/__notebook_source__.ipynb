# CELL 12: Model v3  (fixed for Keras 3 / TF 2.16+)
# ============================================================

class SEBlock(layers.Layer):
    """
    Squeeze-and-Excitation block for 1-D feature vectors.

    Wrapping the logic in a proper Layer subclass avoids the
    KerasTensor / tf.* compatibility error in Keras 3.

    For a 1-D input of shape (batch, units):
      Squeeze  = the vector itself  (already globally pooled)
      Excite   = FC(units//ratio, swish) → FC(units, sigmoid)
      Scale    = element-wise multiply input × excitation weights
    """
    def __init__(self, ratio=8, **kwargs):
        super().__init__(**kwargs)
        self.ratio = ratio

    def build(self, input_shape):
        units          = int(input_shape[-1])
        bottleneck     = max(1, units // self.ratio)
        self.fc_down   = layers.Dense(bottleneck,   activation='swish')
        self.fc_up     = layers.Dense(units,         activation='sigmoid')
        super().build(input_shape)

    def call(self, x):
        # x shape: (batch, units)
        se = self.fc_down(x)   # (batch, units // ratio)
        se = self.fc_up(se)    # (batch, units)
        return x * se          # element-wise scale

    def get_config(self):
        cfg = super().get_config()
        cfg.update({'ratio': self.ratio})
        return cfg


def residual_block_v3(x, units, dropout_rate, l2=0.0005):
    """
    Dense → BN → Swish → Dropout → Dense → BN → SE → Add → Swish
    Skip connection with linear projection when dims differ.
    All ops are Keras-native — compatible with Keras 3.
    """
    shortcut = x

    # Main path
    h = layers.Dense(
            units,
            kernel_regularizer=keras.regularizers.l2(l2),
            use_bias=False                  # BN handles bias
        )(x)
    h = layers.BatchNormalization()(h)
    h = layers.Activation('swish')(h)
    h = layers.Dropout(dropout_rate)(h)

    h = layers.Dense(
            units,
            kernel_regularizer=keras.regularizers.l2(l2),
            use_bias=False
        )(h)
    h = layers.BatchNormalization()(h)

    # SE attention (pure Keras, no tf.* ops)
    h = SEBlock(ratio=8)(h)

    # Skip projection when input / output dims differ
    if int(shortcut.shape[-1]) != units:
        shortcut = layers.Dense(
            units,
            use_bias=False,
            kernel_regularizer=keras.regularizers.l2(l2)
        )(shortcut)
        shortcut = layers.BatchNormalization()(shortcut)

    # Merge + final activation
    h = layers.Add()([h, shortcut])
    h = layers.Activation('swish')(h)
    return h


def create_model_v3(input_dim, num_classes):
    """
    Entry(2048) → ResBlock×5 [1024→512→256→128→64] → Softmax

    Total parameter count ≈ 6.5 M
    """
    inp = keras.Input(shape=(input_dim,), name='features')

    # Entry block
    x = layers.Dense(
            2048,
            kernel_regularizer=keras.regularizers.l2(0.0005),
            use_bias=False,
            name='entry_dense'
        )(inp)
    x = layers.BatchNormalization(name='entry_bn')(x)
    x = layers.Activation('swish',  name='entry_swish')(x)
    x = layers.Dropout(0.4,         name='entry_drop')(x)

    # Residual stack
    block_configs = [
        (1024, 0.40),
        (512,  0.35),
        (256,  0.30),
        (128,  0.25),
        (64,   0.20),
    ]
    for i, (units, drop) in enumerate(block_configs):
        x = residual_block_v3(x, units, drop, l2=0.0005)

    x   = layers.Dropout(0.3, name='pre_output_drop')(x)
    out = layers.Dense(
              num_classes,
              activation='softmax',
              name='output'
          )(x)

    return keras.Model(inp, out, name='EmotionDetector_v3')


# ── Focal loss (pure Keras ops — no tf.clip_by_value) ─────────
def focal_loss(gamma=2.0, alpha=0.25):
    """
    Multiclass focal loss.
    Uses keras.ops instead of tf.* for Keras 3 compatibility.
    """
    def loss_fn(y_true, y_pred):
        # Clip to avoid log(0)
        y_pred = keras.ops.clip(y_pred, 1e-8, 1.0)
        ce     = -y_true * keras.ops.log(y_pred)
        weight = alpha * y_true * keras.ops.power(1.0 - y_pred, gamma)
        fl     = weight * ce
        return keras.ops.mean(keras.ops.sum(fl, axis=-1))
    loss_fn.__name__ = 'focal_loss'
    return loss_fn


