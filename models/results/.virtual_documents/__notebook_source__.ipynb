def predict_emotion_from_audio(audio_path, mdl, scl, le):
    feats = extract_features(audio_path)
    if feats is None:
        return {'error': 'Feature extraction failed'}
    feats_scaled  = scl.transform(feats.reshape(1, -1))
    pred          = mdl.predict(feats_scaled, verbose=0)
    idx           = int(np.argmax(pred))
    probabilities = {le.classes_[i]: float(pred[0][i])
                     for i in range(len(le.classes_))}
    return {
        'predicted_emotion': le.classes_[idx],
        'confidence':        float(pred[0][idx]),
        'all_probabilities': dict(
            sorted(probabilities.items(), key=lambda kv: kv[1], reverse=True)
        )
    }

print("="*70)
print("INFERENCE TEST")
print("="*70)
