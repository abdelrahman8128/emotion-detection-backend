# ============================================================
# CELL 12b: Dual-Input Model
# Branch A : CNN on mel-spectrogram image  (128×128×1)
# Branch B : Residual MLP on tabular features  (622-dim)
# Fusion   : concatenate → dense → softmax
# ============================================================

def build_cnn_branch(input_shape=(128, 128, 1)):
    """
    Lightweight CNN for mel-spectrogram images.
    3 conv blocks + global average pooling → 256-dim embedding.
    """
    inp = keras.Input(shape=input_shape, name='mel_image')

    # Block 1
    x = layers.Conv2D(32, (3, 3), padding='same', use_bias=False)(inp)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.Conv2D(32, (3, 3), padding='same', use_bias=False)(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.MaxPooling2D((2, 2))(x)
    x = layers.Dropout(0.25)(x)

    # Block 2
    x = layers.Conv2D(64, (3, 3), padding='same', use_bias=False)(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.Conv2D(64, (3, 3), padding='same', use_bias=False)(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.MaxPooling2D((2, 2))(x)
    x = layers.Dropout(0.25)(x)

    # Block 3
    x = layers.Conv2D(128, (3, 3), padding='same', use_bias=False)(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.Conv2D(128, (3, 3), padding='same', use_bias=False)(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.MaxPooling2D((2, 2))(x)
    x = layers.Dropout(0.30)(x)

    # Block 4 — deeper spatial features
    x = layers.Conv2D(256, (3, 3), padding='same', use_bias=False)(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.GlobalAveragePooling2D()(x)  # → (batch, 256)
    x = layers.Dropout(0.40)(x)

    return keras.Model(inp, x, name='cnn_branch')


def build_mlp_branch(input_dim):
    """
    Residual MLP — same as v3 but outputs 256-dim embedding.
    """
    inp = keras.Input(shape=(input_dim,), name='tabular_features')

    x = layers.Dense(1024, use_bias=False,
                     kernel_regularizer=keras.regularizers.l2(0.0005))(inp)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('swish')(x)
    x = layers.Dropout(0.40)(x)

    for units, drop in [(512, 0.35), (256, 0.30)]:
        x = residual_block_v3(x, units, drop)

    return keras.Model(inp, x, name='mlp_branch')


def build_dual_model(tab_dim, num_classes):
    """
    Fuse CNN + MLP embeddings → classify.
    """
    cnn_branch = build_cnn_branch(input_shape=(128, 128, 1))
    mlp_branch = build_mlp_branch(input_dim=tab_dim)

    # Inputs
    img_inp = keras.Input(shape=(128, 128, 1), name='mel_image')
    tab_inp = keras.Input(shape=(tab_dim,),    name='tabular_features')

    cnn_out = cnn_branch(img_inp)   # (batch, 256)
    mlp_out = mlp_branch(tab_inp)   # (batch, 256)

    # Fusion
    fused = layers.Concatenate()([cnn_out, mlp_out])   # (batch, 512)
    fused = layers.Dense(256, use_bias=False,
                         kernel_regularizer=keras.regularizers.l2(0.0005))(fused)
    fused = layers.BatchNormalization()(fused)
    fused = layers.Activation('swish')(fused)
    fused = layers.Dropout(0.35)(fused)

    fused = layers.Dense(128, use_bias=False,
                         kernel_regularizer=keras.regularizers.l2(0.0005))(fused)
    fused = layers.BatchNormalization()(fused)
    fused = layers.Activation('swish')(fused)
    fused = layers.Dropout(0.25)(fused)

    out = layers.Dense(num_classes, activation='softmax', name='output')(fused)

    return keras.Model(
        inputs={'mel_image': img_inp, 'tabular_features': tab_inp},
        outputs=out,
        name='DualInputEmotionDetector'
    )


