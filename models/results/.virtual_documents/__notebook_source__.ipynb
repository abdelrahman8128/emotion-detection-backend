    sample = df_combined.sample(1).iloc[0]
    result = predict_emotion_from_audio(
        sample['path'], best_model, scaler, label_encoder
    )
    if 'error' in result:
        print(f"✗  Error: {result['error']}")
        continue
    match = "✓" if result['predicted_emotion'] == sample['emotion'] else "✗"
    print(f"{match}  True: {sample['emotion']:10s} | "
          f"Pred: {result['predicted_emotion']:10s} "
          f"({result['confidence']*100:.1f}%)")

