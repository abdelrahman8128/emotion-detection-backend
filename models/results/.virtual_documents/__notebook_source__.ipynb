# ============================================================
# CELL 5b: Mel-Spectrogram Image Extractor
# Produces a (128 × 128) image for the CNN branch
# ============================================================
def extract_melspec_image(file_path, duration=3, sr=22050,
                          n_mels=128, augment=False):
    """
    Returns a (128, 128, 1) float32 array — mel-spectrogram image.
    Used by the CNN branch of the dual-input model.
    """
    try:
        load_kwargs = dict(duration=duration, sr=sr)
        if RES_TYPE is not None:
            load_kwargs["res_type"] = RES_TYPE

        audio, sample_rate = librosa.load(file_path, **load_kwargs)

        target_len = sr * duration
        if len(audio) < target_len:
            audio = np.pad(audio, (0, target_len - len(audio)), mode='constant')
        else:
            audio = audio[:target_len]

        if augment:
            audio = augment_audio(audio, sample_rate)
            if len(audio) < target_len:
                audio = np.pad(audio, (0, target_len - len(audio)), mode='constant')
            else:
                audio = audio[:target_len]

        # Mel-spectrogram → dB
        mel  = librosa.feature.melspectrogram(
            y=audio, sr=sample_rate, n_mels=n_mels,
            n_fft=2048, hop_length=512
        )
        mel_db = librosa.power_to_db(mel, ref=np.max)

        # Resize to fixed (128 × 128) using simple interpolation
        # so every sample has the same shape regardless of duration
        from PIL import Image
        img = Image.fromarray(mel_db).resize((128, 128), Image.BILINEAR)
        img_arr = np.array(img, dtype=np.float32)

        # Normalise to [0, 1]
        img_arr = (img_arr - img_arr.min()) / (img_arr.max() - img_arr.min() + 1e-8)

        return img_arr[..., np.newaxis]   # (128, 128, 1)

    except Exception as e:
        print(f"Error (melspec image) {file_path}: {e}")
        return None

print("✓ extract_melspec_image() defined")


