# CELL 17c: Test-Time Augmentation (TTA) for better predictions
# ============================================================
"""
TTA: run each test sample through the model N times with slight
feature perturbations, then average the predictions.
Works without retraining — free accuracy boost at inference time.
"""
print("\n" + "="*70)
print("TEST-TIME AUGMENTATION (TTA)")
print("="*70)

def predict_with_tta(model, X, n_runs=10, noise_std=0.01):
    """
    Average predictions over `n_runs` passes, each with tiny
    Gaussian noise added to the normalised features.
    noise_std=0.01 is ~1% perturbation — small enough not to
    change the label, large enough to diversify predictions.
    """
    preds = np.zeros((len(X), num_classes), dtype=np.float32)
    for _ in range(n_runs):
        noise    = np.random.normal(0, noise_std, X.shape).astype(np.float32)
        X_noisy  = X + noise
        preds   += best_model.predict(X_noisy, verbose=0, batch_size=256)
    return preds / n_runs


print("Running TTA (10 passes per sample)...")
y_pred_tta   = predict_with_tta(best_model, X_test_scaled, n_runs=10)
y_pred_tta_c = np.argmax(y_pred_tta, axis=1)

tta_accuracy  = accuracy_score(y_test_classes, y_pred_tta_c)
tta_precision = precision_score(y_test_classes, y_pred_tta_c,
                                average='weighted', zero_division=0)
tta_recall    = recall_score(y_test_classes, y_pred_tta_c,
                             average='weighted', zero_division=0)
tta_f1        = f1_score(y_test_classes, y_pred_tta_c,
                         average='weighted', zero_division=0)

print(f"\n📊 TTA Performance:")
print(f"  Accuracy  : {tta_accuracy  * 100:.2f}%  "
      f"(Δ={( tta_accuracy - test_accuracy)*100:+.2f}%)")
print(f"  Precision : {tta_precision * 100:.2f}%")
print(f"  Recall    : {tta_recall    * 100:.2f}%")
print(f"  F1 Score  : {tta_f1        * 100:.2f}%")

print("\n" + "="*70)
print("CLASSIFICATION REPORT WITH TTA")
