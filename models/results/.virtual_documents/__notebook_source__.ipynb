def mixup_dual_batch(Xt, Xi, y, alpha=0.3):
    """Mixup for dual inputs (tabular + image)."""
    if alpha <= 0:
        return Xt, Xi, y
    lam  = np.random.beta(alpha, alpha)
    idx  = np.random.permutation(len(Xt))
    Xt_m = lam * Xt + (1 - lam) * Xt[idx]
    Xi_m = lam * Xi + (1 - lam) * Xi[idx]
    y_m  = lam * y  + (1 - lam) * y[idx]
    return (Xt_m.astype(np.float32),
            Xi_m.astype(np.float32),
            y_m.astype(np.float32))


def train_dual_with_mixup(model, Xt_tr, Xi_tr, y_tr,
                          Xt_v, Xi_v, y_v,
                          epochs, batch_size, cbs,
                          cw_dict, alpha=0.3):

    best_val   = 0.0
    patience_c = 0
    PATIENCE   = 35
    hist       = {'accuracy': [], 'val_accuracy': [],
                  'loss': [],     'val_loss': []}

    n_batches  = int(np.ceil(len(Xt_tr) / batch_size))

    for cb in cbs:
        cb.set_model(model)
        if hasattr(cb, 'set_params'):
            cb.set_params({'epochs': epochs, 'steps': n_batches,
                           'verbose': 1, 'do_validation': True,
                           'metrics': ['loss','accuracy',
                                       'val_loss','val_accuracy']})
    for cb in cbs:
        if hasattr(cb, 'on_train_begin'):
            cb.on_train_begin()

    for epoch in range(epochs):
        for cb in cbs:
            if hasattr(cb, 'on_epoch_begin'):
                cb.on_epoch_begin(epoch, logs={})

        perm    = np.random.permutation(len(Xt_tr))
        Xt_shuf = Xt_tr[perm]
        Xi_shuf = Xi_tr[perm]
        y_shuf  = y_tr[perm]

        ep_losses, ep_accs = [], []

        for b in range(n_batches):
            s   = b * batch_size
            e   = s + batch_size
            Xtb = Xt_shuf[s:e]
            Xib = Xi_shuf[s:e]
            yb  = y_shuf[s:e]

            Xtb_m, Xib_m, yb_m = mixup_dual_batch(Xtb, Xib, yb, alpha)

            res = model.train_on_batch(
                {'mel_image': Xib_m, 'tabular_features': Xtb_m},
                yb_m,
                class_weight=cw_dict
            )
            ep_losses.append(float(res[0]))
            ep_accs.append(float(res[1]))

        val_res   = model.evaluate(
            {'mel_image': Xi_v, 'tabular_features': Xt_v},
            y_v, verbose=0, batch_size=128
        )
        val_loss  = float(val_res[0])
        val_acc   = float(val_res[1])
        tr_loss   = float(np.mean(ep_losses))
        tr_acc    = float(np.mean(ep_accs))
        cur_lr    = float(keras.backend.get_value(
                        model.optimizer.learning_rate))

        hist['loss'].append(tr_loss)
        hist['accuracy'].append(tr_acc)
        hist['val_loss'].append(val_loss)
        hist['val_accuracy'].append(val_acc)

        logs = {'loss': tr_loss, 'accuracy': tr_acc,
                'val_loss': val_loss, 'val_accuracy': val_acc,
                'lr': cur_lr}

        stop = False
        for cb in cbs:
            if hasattr(cb, 'on_epoch_end'):
                cb.on_epoch_end(epoch, logs=logs)
            if getattr(cb, 'stop_training', False):
                stop = True

        print(f"Epoch {epoch+1:3d}/{epochs}  "
              f"loss={tr_loss:.4f}  acc={tr_acc:.4f}  "
              f"val_loss={val_loss:.4f}  val_acc={val_acc:.4f}  "
              f"lr={cur_lr:.2e}")

        if val_acc > best_val:
            best_val   = val_acc
            patience_c = 0
            model.save('checkpoints/best_dual_model.keras')
            print(f"  ✓ Best val_acc={best_val:.4f} — saved")
        else:
            patience_c += 1

        if stop:
            print(f"\nEarly stop at epoch {epoch+1} "
                  f"(best={best_val:.4f})")
            break

    for cb in cbs:
        if hasattr(cb, 'on_train_end'):
            cb.on_train_end()

    return hist


