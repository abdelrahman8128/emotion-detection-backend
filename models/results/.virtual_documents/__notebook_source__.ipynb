# ── Step 1: Merge 'calm' into 'neutral' ──────────────────────
# Rationale:
#   • calm has only 384 samples — far too few to learn reliably
#   • Calm speech is acoustically very close to neutral
#     (low arousal, low valence) — standard practice in SER research
#   • Merging avoids the model learning a near-random calm classifier
#     that would hurt overall accuracy

CALM_COUNT = (df_combined['emotion'] == 'calm').sum()
print(f"\nStep 1 — Merging 'calm' → 'neutral'")
print(f"  calm samples that will become neutral: {CALM_COUNT}")
df_combined['emotion'] = df_combined['emotion'].replace('calm', 'neutral')
print("  ✓ Done")

# ── Step 2: Cap majority classes ─────────────────────────────
# We cap at 3000 per emotion:
#   • Keeps total dataset manageable for Kaggle (time / RAM)
#   • Prevents the 3 majority classes from dominating gradients
TARGET_CAP = 3000

print(f"\nStep 2 — Capping majority classes at {TARGET_CAP} samples each")
df_capped = (
    df_combined
    .groupby('emotion', group_keys=False)
    .apply(lambda x: x.sample(min(len(x), TARGET_CAP), random_state=42))
    .reset_index(drop=True)
)

print("\n  Distribution after capping:")
print(df_capped['emotion'].value_counts().to_string())

# ── Step 3: Augment minority classes to reach TARGET_AUG ─────
# We synthesise EXTRA rows (with augment=True flag) so that every
# class reaches TARGET_AUG samples.  The actual audio augmentation
# (noise / stretch / pitch) happens inside extract_features() later.

TARGET_AUG = 2000   # every class will have at least this many rows

print(f"\nStep 3 — Augmenting minority classes up to {TARGET_AUG} samples")
current_counts = df_capped['emotion'].value_counts()
aug_rows = []

for emotion, count in current_counts.items():
    if count < TARGET_AUG:
        needed     = TARGET_AUG - count
        pool       = df_capped[df_capped['emotion'] == emotion]
        # Sample WITH replacement to get as many rows as needed
        extra      = pool.sample(needed, replace=True, random_state=42).copy()
        extra['augment_flag'] = True    # tells feature extractor to augment
        aug_rows.append(extra)
        print(f"  {emotion:12s}: {count:4d} → +{needed} augmented copies "
              f"→ {count + needed} total")
    else:
        print(f"  {emotion:12s}: {count:4d} — no augmentation needed")

# Combine original + synthetic rows
df_capped['augment_flag'] = False
if aug_rows:
    df_balanced = pd.concat([df_capped] + aug_rows, ignore_index=True)
else:
    df_balanced = df_capped.copy()

# Shuffle so augmented rows aren't all at the end
df_balanced = df_balanced.sample(frac=1, random_state=42).reset_index(drop=True)

