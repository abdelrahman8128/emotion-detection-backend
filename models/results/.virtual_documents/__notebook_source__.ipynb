# ============================================================
# CELL 1b: Resampling Backend Selector  ← REPLACE THIS CELL
# ============================================================
"""
find_spec() only checks the file system — it does NOT verify the
package actually works.  We must do a real librosa.load test with
a tiny synthetic signal to confirm each backend truly functions.
"""
import numpy as np
import soundfile as sf
import tempfile, os, importlib

def get_res_type():
    """
    Determine the best working resampling backend by actually
    calling librosa.load — not just checking if the package exists.
    """
    import librosa

    # Create a tiny 0.1-second silent WAV in a temp file
    tmp_sr   = 44100
    tmp_sig  = np.zeros(tmp_sr // 10, dtype=np.float32)   # 0.1 s silence
    tmp_path = os.path.join(tempfile.gettempdir(), "_res_test.wav")
    sf.write(tmp_path, tmp_sig, tmp_sr)

    candidates = [
        ("resampy", "kaiser_fast"),
        ("soxr",    "soxr_hq"),
        ("scipy",   "scipy"),       # always present in Kaggle
    ]

    for module_name, res_type in candidates:
        # First check the package is on disk at all
        if importlib.util.find_spec(module_name) is None:
            print(f"  ✗ {module_name:10s} not found on disk — skipping")
            continue

        # NOW actually try to use it through librosa
        try:
            librosa.load(tmp_path, sr=22050, res_type=res_type)
            print(f"  ✓ {module_name:10s} works  →  res_type='{res_type}'")
            os.remove(tmp_path)
            return res_type
        except Exception as e:
            # Package exists but is broken (common after pip install
            # without kernel restart)
            short_err = str(e).split("\n")[0][:120]
            print(f"  ✗ {module_name:10s} found but FAILED: {short_err}")
            continue

    # Should never reach here because scipy ships with Kaggle
    os.remove(tmp_path)
    print("  ⚠ No resampler passed the live test — using librosa default")
    return None


print("=" * 60)
print("TESTING RESAMPLING BACKENDS (live test)")
print("=" * 60)

RES_TYPE = get_res_type()

print()
print(f"{'='*60}")
print(f"  RES_TYPE = '{RES_TYPE}'")
print(f"{'='*60}")

if RES_TYPE is None:
    print("⚠ librosa will use its own default resampler")
else:
    print(f"✅ All librosa.load calls will use  res_type='{RES_TYPE}'")


