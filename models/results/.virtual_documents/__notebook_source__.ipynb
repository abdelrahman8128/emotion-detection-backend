"""
Only install what is strictly needed and not already present.
- librosa, soundfile, resampy, soxr  → audio loading & processing
- audiomentations is NOT used (augmentation is done manually)
"""
import subprocess, sys, importlib

def safe_install(package, import_name=None):
    """Install a package only if it cannot be imported."""
    import_name = import_name or package
    if importlib.util.find_spec(import_name) is not None:
        print(f"  ✓ {package} already available — skipping install")
        return True
    print(f"  ⬇ Installing {package} ...")
    result = subprocess.run(
        [sys.executable, "-m", "pip", "install", "-q", package],
        capture_output=True, text=True
    )
    if result.returncode == 0:
        print(f"  ✓ {package} installed successfully")
        return True
    else:
        print(f"  ✗ {package} install FAILED — will try to continue anyway")
        print(f"    stderr: {result.stderr[-300:]}")   # last 300 chars only
        return False

print("=" * 60)
print("INSTALLING / VERIFYING DEPENDENCIES")
print("=" * 60)

# These are the ONLY external packages we need
safe_install("librosa")
safe_install("soundfile")
